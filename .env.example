# costrategy 本地环境变量示例
#
# 后端会从当前工作目录读取 `.env`。本地启动后端时，先把本文件复制到
# `backend/.env`，再把占位值替换成本机真实配置。
# 不要把真实密钥写入本示例文件。

# -----------------------------------------------------------------------------
# 后端：必填 PostgreSQL 配置
# -----------------------------------------------------------------------------
# 推荐使用 DATABASE_URL。密码和数据库名包含特殊字符时需要 URL 编码。
DATABASE_URL=postgres://costrategy:costrategy@127.0.0.1:5432/costrategy

# 如果不使用 DATABASE_URL，当前后端配置解析器也支持以下拆分写法：
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_USER=costrategy
# POSTGRES_PASSWORD=costrategy
# POSTGRES_DB=costrategy

# -----------------------------------------------------------------------------
# 后端：必填 RustFS / S3 兼容对象存储配置
# -----------------------------------------------------------------------------
RUSTFS_ENDPOINT=127.0.0.1:9000
RUSTFS_REGION=cn-east-1
RUSTFS_BUCKET=costrategy-files
RUSTFS_ACCESS_KEY_ID=rustfs-access-key
RUSTFS_SECRET_ACCESS_KEY=rustfs-secret-key

# -----------------------------------------------------------------------------
# 后端：可选钉钉配置
# -----------------------------------------------------------------------------
# 不配置任何钉钉变量时，后端可以在无真实钉钉集成的情况下启动。
# 如果设置了任意钉钉变量，则下面这些必填钉钉变量都必须存在。
DINGTALK_CORP_ID=ding-corp-id
DINGTALK_CLIENT_ID=ding-client-id
DINGTALK_CLIENT_SECRET=ding-client-secret
DINGTALK_AGENT_ID=123456
DINGTALK_OAPI_BASE_URL=https://oapi.dingtalk.com

# 当前后端也支持以下别名：
# DINGTALK_APP_KEY=ding-client-id
# DINGTALK_APP_SECRET=ding-client-secret

# -----------------------------------------------------------------------------
# 前端：可选 API 地址
# -----------------------------------------------------------------------------
# Vite 开发模式默认把 `/api` 代理到 http://127.0.0.1:8080。
# 只有需要绕过开发代理时，才在 `frontend/.env` 中设置这个变量。
VITE_API_BASE_URL=http://127.0.0.1:8080/api

# -----------------------------------------------------------------------------
# 开发计划中的预留配置，当前后端尚未读取
# -----------------------------------------------------------------------------
# APP_JWT_SECRET=change-me
# APP_CONFIG_MASTER_KEY=change-me-32-bytes-or-managed-secret
# DINGTALK_APP_ID=ding-app-id
# DINGTALK_CALLBACK_URL=https://example.com/dingtalk/callback
# RUSTFS_USE_HTTPS=false
# RUSTFS_PUBLIC_BASE_URL=http://127.0.0.1:9000
