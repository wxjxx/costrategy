                      "content": "由 Tiptap 驱动",
                      "lineHeight": 1.18,
                      "textAlign": "right",
                      "textAlignVertical": "middle",
                      "fontFamily": "Noto Sans SC",
                      "fontSize": 11
                    }
                  ]
                }
              ]
